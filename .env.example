# ==============================================
# RBIN App Monitor - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ==============================================
# Application Configuration
# ==============================================
# The base URL of your deployed application
# Used for generating dashboard links in notifications
# Example: https://your-app.vercel.app or http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# Firebase Client Configuration (Public)
# ==============================================
# These variables are exposed to the browser
# Get these values from Firebase Console > Project Settings > General > Your apps
# https://console.firebase.google.com/
#
# IMPORTANT: Enable Google Sign-In Provider:
# 1. Go to Firebase Console > Authentication > Sign-in method
# 2. Enable "Google" provider
# 3. Set your project support email
# 4. For production, add your domain to authorized domains

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ==============================================
# Firebase Admin Configuration (Server-side)
# ==============================================
# Choose ONE of the following options:

# --- Option 1: Service Account JSON (Recommended for Production/Vercel) ---
# Get from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content as a single line (or use escaped JSON string)
# Example: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Option 2: Individual Environment Variables (Alternative) ---
# Use these if you prefer not to use the JSON format above
# Extract these values from the service account JSON
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ==============================================
# Email Notifications
# ==============================================
# Alerts (health check failed/restored, Cypress failed) are sent to NOTIFICATION_EMAIL_TO
#
# Option A - Resend (recommended, free tier: 100 emails/day, 3k/month)
# https://resend.com - create API key at https://resend.com/api-keys
# No SMTP needed; use onboarding@resend.dev for testing or verify your domain
RESEND_API_KEY=re_your_api_key_here
NOTIFICATION_EMAIL_TO=your@email.com
# Optional: From address (default: App Monitor <onboarding@resend.dev>)
# RESEND_FROM=App Monitor <noreply@yourdomain.com>
#
# Option B - SMTP (any provider: Gmail, SendGrid, Mailgun, etc.)
# Uncomment and set if not using Resend
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# NOTIFICATION_EMAIL_TO=alerts@example.com
# NOTIFICATION_EMAIL_FROM=noreply@yourdomain.com

# ==============================================
# API Security
# ==============================================
# Secret key for cron job authentication (REQUIRED for production)
# Generate a random secret: openssl rand -base64 32
# This is used to protect /api/cron/health-check and /api/cron/cypress endpoints
CRON_SECRET=your_random_secret_key_here

# Optional: Additional API secret key for other endpoints
# Generate a random secret: openssl rand -base64 32
# API_SECRET_KEY=your_api_secret_key_here

# ==============================================
# Notes
# ==============================================
# 1. For local development, copy this file to .env.local
# 2. For Vercel deployment:
#    - Add all variables in Vercel dashboard: Project Settings > Environment Variables
#    - Make sure NEXT_PUBLIC_APP_URL is set to your Vercel deployment URL
#    - Use FIREBASE_SERVICE_ACCOUNT_KEY (Option 1) for easier configuration
# 3. For Firebase Hosting:
#    - Firebase Hosting only supports static pages
#    - API routes require Vercel or Firebase Functions
# 4. Security:
#    - Never commit .env.local or .env files to git
#    - Keep your secrets secure and rotate them regularly
#    - Use different credentials for development and production
